# ─────────────────────────────────────────────────────────────
# PacketTime Debugger — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── App Environment ──────────────────────────────────────────
# "development" enables DevTools on launch
# "production"  disables DevTools, enables optimisations
NODE_ENV=development

# ── Window behaviour ─────────────────────────────────────────
# Set to "true" to open DevTools automatically on launch (dev only)
OPEN_DEVTOOLS=false

# ── GitHub Release Publishing ────────────────────────────────
# Required only when running: electron-builder --publish always
# In CI (GitHub Actions) this is set automatically via secrets.GITHUB_TOKEN
# Locally: generate a token at https://github.com/settings/tokens
#   → Scopes needed: repo (full)
GH_TOKEN=your_github_token_here

# ── Future: AI Integration ───────────────────────────────────
# Uncomment and fill in when adding the AI Q&A assistant feature
# ANTHROPIC_API_KEY=your_api_key_here
# AI_MODEL=claude-opus-4-5
# AI_MAX_TOKENS=1024
